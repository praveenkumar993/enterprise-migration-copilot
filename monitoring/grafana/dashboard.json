  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Request Rate by Source Language",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(migration_requests_total[1m])) by (source_language)",
          "legendFormat": "{{source_language}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "stacking": { "mode": "normal" } }
        }
      },
      "description": "Requests per minute, stacked by source language (sql, hiveql, plsql, stored_procedure)"
    },
    {
      "id": 2,
      "title": "Migration Success Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(migration_requests_total{status=\"success\"}[5m])) / sum(rate(migration_requests_total[5m])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 85 }
            ]
          }
        }
      },
      "description": "Percentage of migrations with status=success over last 5 minutes"
    },
    {
      "id": 3,
      "title": "P95 Migration Latency",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(migration_duration_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "description": "95th percentile end-to-end migration pipeline latency"
    },
    {
      "id": 4,
      "title": "Per-Agent Latency",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(agent_duration_seconds_bucket[5m])) by (le, agent_name))",
          "legendFormat": "{{agent_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "description": "Median latency per agent: analyzer, migrator, validator, reviewer, optimizer, risk_compliance"
    },
    {
      "id": 5,
      "title": "Risk Score Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(risk_score_histogram_bucket[15m])) by (le)",
          "refId": "A"
        }
      ],
      "description": "Distribution of risk scores (0-10) across all migrations"
    },
    {
      "id": 6,
      "title": "Source Language Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(migration_requests_total) by (source_language)",
          "legendFormat": "{{source_language}}",
          "refId": "A"
        }
      ],
      "description": "Total migration requests broken down by source language"
    },
    {
      "id": 7,
      "title": "Procedural Flags by Type",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(procedural_flags_counter) by (flag_type)",
          "legendFormat": "{{flag_type}}",
          "refId": "A"
        }
      ],
      "description": "Fintech-relevant: count of procedural constructs flagged for manual review (CURSOR, EXCEPTION, TEMP TABLE, etc.)"
    }
  ],
